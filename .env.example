# Database
DATABASE_URL=postgresql+psycopg://interngram:interngram@localhost:5432/interngram

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=change-me-to-a-long-random-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# AWS S3 (LocalStack for local dev)
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_REGION=us-east-1
S3_BUCKET=interngram-uploads
S3_ENDPOINT_URL=http://localhost:4566

# CORS
CORS_ORIGINS=http://localhost:3000

# App
APP_ENV=development
CSRF_SECRET=change-me-csrf-secret

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
